# Oil Market Exploration

# This notebook demonstrates how oil prices react to major geopolitical events
# using a simple window-based approach.

import yfinance as yf
import pandas as pd
import matplotlib.pyplot as plt

# Load Brent oil data
oil = yf.download("BZ=F", start="2015-01-01")

print("\n=== Data Preview ===")
print(oil.head())

# Plot oil prices
plt.figure(figsize=(12,5))
oil['Close'].plot(title="Brent Oil Price Over Time")
plt.show()

# Example Event: Russia-Ukraine War
# We measure impact using a 3-day window before and after the event

event_date = "2022-02-24"

idx = oil.index.get_indexer([pd.to_datetime(event_date)], method='nearest')[0]

before = oil.iloc[idx-3:idx]['Close'].mean()
after = oil.iloc[idx+1:idx+4]['Close'].mean()

impact = ((after - before) / before) * 100

print("\n=== Event Impact ===")
print(f"Event Date: {event_date}")
print(f"Impact: {impact:.2f}%")

# Interpretation
print("\n=== Interpretation ===")
print("The result shows a measurable price reaction following the event.")
print("This demonstrates how geopolitical shocks can influence oil markets.")
